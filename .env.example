# ── HuggingFace (free embeddings — all-MiniLM-L6-v2) ──────────────────────────
# Get free token at https://huggingface.co → Settings → Access Tokens
HF_TOKEN=your_hf_token_here

# ── Google Gemini (primary LLM — free tier, 1500 req/day) ─────────────────────
# Get free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── OpenRouter (fallback LLM — free models) ────────────────────────────────────
# Get free key at https://openrouter.ai → Sign up → Keys
OPENROUTER_API_KEY=your_openrouter_key_here

# ── Qdrant Vector Database ─────────────────────────────────────────────────────
# Option A: Local → docker run -p 6333:6333 qdrant/qdrant
# Option B: Cloud (free) → https://cloud.qdrant.io
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
SITE_URL=http://localhost:3000
